{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/riomadre/proof-of-regeneration/schemas/observation.schema.json",
"title": "Proof of Regeneration Observation",
"description": "Schema for a field observation processed through the Proof of Regeneration workflow.",
"type": "object",
"additionalProperties": false,
"required": [
"schema_version",
"record_id",
"record_type",
"observation",
"location",
"evidence",
"ai_analysis",
"review",
"publication"
],
"properties": {
"schema_version": {
"type": "string",
"const": "0.1.0",
"description": "Version of this observation schema."
},
"record_id": {
"type": "string",
"pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
"description": "Unique lowercase identifier for the observation, for example rm-2026-0001."
},
"record_type": {
"type": "string",
"enum": [
"ecological_observation",
"restoration_activity",
"agroforestry_activity",
"watershed_condition",
"landscape_condition",
"human_disturbance",
"follow_up_observation"
]
},
"parent_record_id": {
"type": [
"string",
"null"
],
"pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
"description": "Identifier of an earlier record when this observation is a follow-up."
},
"observation": {
"type": "object",
"additionalProperties": false,
"required": [
"observed_at",
"category",
"field_note",
"contributor_id"
],
"properties": {
"observed_at": {
"type": "string",
"format": "date-time",
"description": "Date and time of the observation in ISO 8601 format."
},
"category": {
"type": "string",
"enum": [
"flora",
"fauna",
"fungi",
"wildlife_sign",
"watershed",
"soil",
"weather_context",
"restoration",
"agroforestry",
"human_disturbance",
"other"
]
},
"field_note": {
"type": "string",
"minLength": 1,
"maxLength": 5000,
"description": "Original note written by the field observer."
},
"contributor_id": {
"type": "string",
"minLength": 1,
"maxLength": 100,
"description": "An anonymized or authorized contributor identifier."
},
"habitat": {
"type": [
"string",
"null"
],
"maxLength": 250
},
"weather_context": {
"type": [
"string",
"null"
],
"maxLength": 1000
}
}
},
"location": {
"type": "object",
"additionalProperties": false,
"required": [
"site",
"public_precision",
"sensitivity"
],
"properties": {
"site": {
"type": "string",
"minLength": 1,
"maxLength": 200,
"description": "General site name, for example Rio Madre."
},
"private_coordinates": {
"oneOf": [
{
"$ref": "#/$defs/coordinates"
},
{
"type": "null"
}
]
},
"public_zone": {
"type": [
"string",
"null"
],
"maxLength": 200,
"description": "Generalized habitat or landscape zone suitable for publication."
},
"public_precision": {
"type": "string",
"enum": [
"exact",
"rounded",
"zone",
"site_only",
"hidden"
]
},
"sensitivity": {
"type": "string",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"sensitivity_reason": {
"type": [
"string",
"null"
],
"maxLength": 1000
}
}
},
"evidence": {
"type": "object",
"additionalProperties": false,
"required": [
"images",
"source_note_hash"
],
"properties": {
"images": {
"type": "array",
"minItems": 1,
"maxItems": 10,
"items": {
"$ref": "#/$defs/imageEvidence"
}
},
"source_note_hash": {
"$ref": "#/$defs/sha256"
},
"input_bundle_hash": {
"oneOf": [
{
"$ref": "#/$defs/sha256"
},
{
"type": "null"
}
]
}
}
},
"ai_analysis": {
"type": "object",
"additionalProperties": false,
"required": [
"status",
"provisional_classification",
"visible_evidence",
"alternative_interpretations",
"confidence",
"uncertainty",
"human_review_priority",
"location_sensitivity",
"recommended_follow_up"
],
"properties": {
"status": {
"type": "string",
"enum": [
"not_run",
"completed",
"failed",
"invalid_output"
]
},
"provisional_classification": {
"type": [
"string",
"null"
],
"maxLength": 500,
"description": "Provisional interpretation only, not a confirmed identification."
},
"classification_level": {
"type": [
"string",
"null"
],
"enum": [
"species",
"genus",
"family",
"broad_group",
"condition",
"activity",
"unresolved",
null
]
},
"visible_evidence": {
"type": "array",
"maxItems": 20,
"items": {
"type": "string",
"minLength": 1,
"maxLength": 500
}
},
"alternative_interpretations": {
"type": "array",
"maxItems": 10,
"items": {
"type": "string",
"minLength": 1,
"maxLength": 500
}
},
"confidence": {
"type": [
"number",
"null"
],
"minimum": 0,
"maximum": 1
},
"uncertainty": {
"type": "string",
"maxLength": 2000
},
"human_review_priority": {
"type": "string",
"enum": [
"low",
"medium",
"high",
"urgent"
]
},
"location_sensitivity": {
"type": "string",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"recommended_follow_up": {
"type": "array",
"maxItems": 10,
"items": {
"type": "string",
"minLength": 1,
"maxLength": 500
}
},
"legal_or_responsibility_claim_detected": {
"type": "boolean",
"default": false,
"description": "True when the output may contain an unsupported legal, ownership, intent, or responsibility claim."
}
}
},
"inference": {
"type": [
"object",
"null"
],
"additionalProperties": false,
"required": [
"provider",
"model",
"prompt_version"
],
"properties": {
"provider": {
"type": "string",
"enum": [
"mock",
"nosana"
]
},
"job_id": {
"type": [
"string",
"null"
],
"maxLength": 500
},
"model": {
"type": "string",
"minLength": 1,
"maxLength": 500
},
"model_version": {
"type": [
"string",
"null"
],
"maxLength": 500
},
"container_image": {
"type": [
"string",
"null"
],
"maxLength": 1000
},
"container_digest": {
"type": [
"string",
"null"
],
"maxLength": 500
},
"prompt_version": {
"type": "string",
"minLength": 1,
"maxLength": 100
},
"started_at": {
"type": [
"string",
"null"
],
"format": "date-time"
},
"completed_at": {
"type": [
"string",
"null"
],
"format": "date-time"
},
"runtime_seconds": {
"type": [
"number",
"null"
],
"minimum": 0
},
"estimated_cost_usd": {
"type": [
"number",
"null"
],
"minimum": 0
},
"raw_output_hash": {
"oneOf": [
{
"$ref": "#/$defs/sha256"
},
{
"type": "null"
}
]
}
}
},
"review": {
"type": "object",
"additionalProperties": false,
"required": [
"status",
"reviewer_id",
"reviewed_at",
"final_interpretation",
"corrections",
"follow_up_required"
],
"properties": {
"status": {
"type": "string",
"enum": [
"pending",
"approved",
"approved_with_minor_edits",
"corrected",
"rejected",
"follow_up_required"
]
},
"reviewer_id": {
"type": [
"string",
"null"
],
"maxLength": 100
},
"reviewed_at": {
"type": [
"string",
"null"
],
"format": "date-time"
},
"final_interpretation": {
"type": [
"string",
"null"
],
"maxLength": 5000
},
"corrections": {
"type": "array",
"maxItems": 50,
"items": {
"$ref": "#/$defs/correction"
}
},
"follow_up_required": {
"type": "boolean"
},
"review_notes": {
"type": [
"string",
"null"
],
"maxLength": 5000
},
"reviewed_output_hash": {
"oneOf": [
{
"$ref": "#/$defs/sha256"
},
{
"type": "null"
}
]
}
}
},
"publication": {
"type": "object",
"additionalProperties": false,
"required": [
"status",
"image_visibility",
"location_visibility",
"approved_for_permanent_storage"
],
"properties": {
"status": {
"type": "string",
"enum": [
"private",
"restricted",
"public",
"archived",
"rejected"
]
},
"image_visibility": {
"type": "string",
"enum": [
"private",
"redacted",
"public"
]
},
"location_visibility": {
"type": "string",
"enum": [
"exact",
"rounded",
"zone",
"site_only",
"hidden"
]
},
"approved_for_permanent_storage": {
"type": "boolean",
"default": false
},
"public_summary": {
"type": [
"string",
"null"
],
"maxLength": 3000
}
}
},
"created_at": {
"type": "string",
"format": "date-time"
},
"updated_at": {
"type": "string",
"format": "date-time"
}
},
"$defs": {
"sha256": {
"type": "string",
"pattern": "^sha256:[a-f0-9]{64}$",
"description": "SHA-256 digest prefixed with sha256:."
},
"coordinates": {
"type": "object",
"additionalProperties": false,
"required": [
"latitude",
"longitude"
],
"properties": {
"latitude": {
"type": "number",
"minimum": -90,
"maximum": 90
},
"longitude": {
"type": "number",
"minimum": -180,
"maximum": 180
},
"accuracy_meters": {
"type": [
"number",
"null"
],
"minimum": 0
}
}
},
"imageEvidence": {
"type": "object",
"additionalProperties": false,
"required": [
"image_id",
"file_name",
"media_type",
"sha256",
"visibility"
],
"properties": {
"image_id": {
"type": "string",
"pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
},
"file_name": {
"type": "string",
"minLength": 1,
"maxLength": 500
},
"media_type": {
"type": "string",
"enum": [
"image/jpeg",
"image/png",
"image/webp"
]
},
"sha256": {
"$ref": "#/$defs/sha256"
},
"captured_at": {
"type": [
"string",
"null"
],
"format": "date-time"
},
"metadata_removed": {
"type": "boolean",
"default": true
},
"visibility": {
"type": "string",
"enum": [
"private",
"redacted",
"public"
]
},
"alt_text": {
"type": [
"string",
"null"
],
"maxLength": 1000
}
}
},
"correction": {
"type": "object",
"additionalProperties": false,
"required": [
"field",
"original_value",
"corrected_value",
"reason"
],
"properties": {
"field": {
"type": "string",
"minLength": 1,
"maxLength": 250
},
"original_value": {},
"corrected_value": {},
"reason": {
"type": "string",
"minLength": 1,
"maxLength": 2000
}
}
}
}
}
