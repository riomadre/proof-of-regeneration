# Proof of Regeneration

# Example environment variables only.

# Do not place real credentials or secrets in this file.

# Application

NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Nosana

NOSANA_API_KEY=
NOSANA_NETWORK=
NOSANA_MARKET=
NOSANA_DEPLOYMENT_ID=

# Inference

INFERENCE_PROVIDER=mock
MODEL_NAME=
MODEL_VERSION=
PROMPT_VERSION=0.1.0
OBSERVATION_SCHEMA_VERSION=0.1.0
PROVENANCE_SCHEMA_VERSION=0.1.0

# Storage

PRIVATE_STORAGE_ENDPOINT=
PRIVATE_STORAGE_BUCKET=
PRIVATE_STORAGE_REGION=
PRIVATE_STORAGE_ACCESS_KEY=
PRIVATE_STORAGE_SECRET_KEY=

# Database

DATABASE_URL=

# Integrity and Signing

PRIVATE_SIGNING_KEY=
PUBLIC_SIGNING_KEY=
HASH_ALGORITHM=sha256

# Optional Permanent Storage

PERMANENT_STORAGE_PROVIDER=
PERMANENT_STORAGE_API_KEY=

# Logging

LOG_LEVEL=info

# Development Safety

ALLOW_PUBLICATION=false
ALLOW_PERMANENT_STORAGE=false
USE_SYNTHETIC_SAMPLE_DATA=true
